---
interface Props {
  reverse?: boolean;
  number?: string;
  label: string;
  heading: string;
}

const { reverse = false, number, label, heading } = Astro.props;
---

<div class:list={['feature-row', { reverse }]}>
  <div class="meta">
    {number && <span class="num mono">{number}</span>}
    <span class="label mono">{label}</span>
  </div>
  <div class="content">
    <h3 class="heading">{heading}</h3>
    <div class="body">
      <slot />
    </div>
    <div class="aside">
      <slot name="aside" />
    </div>
  </div>
</div>

<style>
  .feature-row {
    display: grid;
    grid-template-columns: 0.6fr 2.2fr;
    gap: 56px;
    padding: 56px 0;
    border-top: 1px solid var(--hair);
  }
  .feature-row:first-child {
    border-top: none;
    padding-top: 16px;
  }
  .feature-row.reverse {
    grid-template-columns: 2.2fr 0.6fr;
  }
  .meta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: sticky;
    top: 96px;
    align-self: start;
  }
  .num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--emerald);
    letter-spacing: 0.18em;
  }
  .label {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--slate);
  }
  .heading {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 2vw + 0.5rem, 2.1rem);
    line-height: 1.1;
    letter-spacing: -0.018em;
    color: var(--ink);
    font-weight: 400;
    margin: 0 0 22px;
    max-width: 22ch;
  }
  .heading :global(em) {
    font-style: italic;
    color: var(--emerald);
  }
  .body {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.55;
    color: var(--slate);
    max-width: 58ch;
  }
  .body :global(em) {
    font-style: italic;
    color: var(--emerald);
  }
  .body :global(p) {
    margin: 0 0 1em;
  }
  .body :global(p:last-child) {
    margin-bottom: 0;
  }
  .aside {
    margin-top: 24px;
  }
  .aside:empty {
    display: none;
  }
  @media (max-width: 900px) {
    .feature-row,
    .feature-row.reverse {
      grid-template-columns: 1fr;
      gap: 22px;
      padding: 48px 0;
    }
    .meta {
      position: static;
      flex-direction: row;
      align-items: baseline;
      gap: 14px;
    }
  }
</style>
