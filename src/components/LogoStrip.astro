---
const cohort = [
  'REI',
  'Backcountry',
  'Patagonia',
  'Moosejaw',
  'Smartwool',
  'Outdoor Voices',
];
---

<div class="strip-inner">
  <span class="strip-label mono">FIRST COHORT · OUTDOOR &amp; ATHLETIC APPAREL</span>
  <ul class="logos">
    {cohort.map((name) => (
      <li class="logo">{name}</li>
    ))}
  </ul>
</div>

<style>
  .strip-inner {
    display: flex;
    align-items: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .strip-label {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--slate);
    flex-shrink: 0;
  }
  .logos {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 26px 32px;
    align-items: baseline;
    flex: 1;
    justify-content: flex-end;
  }
  .logo {
    font-family: var(--serif);
    font-style: italic;
    font-size: 17px;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  @media (max-width: 700px) {
    .logos { justify-content: flex-start; }
  }
</style>
