---
interface Row {
  label: string;
  detail?: string;
  value: string;
  unit?: string;
}

interface Props {
  meter: string;
  caption: string;
  rows: Row[];
}

const { meter, caption, rows } = Astro.props;
---

<div class="meter">
  <header class="meter-head">
    <span class="meter-id mono">{meter}</span>
    <span class="caption">{caption}</span>
  </header>
  <ul class="rows">
    {rows.map((row) => (
      <li class="row">
        <div class="lhs">
          <span class="label">{row.label}</span>
          {row.detail && <span class="detail">{row.detail}</span>}
        </div>
        <div class="rhs">
          <span class="value mono">{row.value}</span>
          {row.unit && <span class="unit mono">{row.unit}</span>}
        </div>
      </li>
    ))}
  </ul>
</div>

<style>
  .meter {
    border: 1px solid var(--hair);
    border-radius: var(--radius-sm);
    background: color-mix(in oklab, var(--bg-soft) 70%, transparent);
  }
  .meter-head {
    padding: 22px 26px 18px;
    border-bottom: 1px solid var(--hair);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .meter-id {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--emerald);
  }
  .caption {
    font-family: var(--serif);
    font-size: 19px;
    line-height: 1.3;
    color: var(--ink);
    letter-spacing: -0.012em;
    font-weight: 400;
  }
  .rows {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 18px;
    padding: 16px 26px;
    border-bottom: 1px solid var(--hair);
    margin: 0;
  }
  .row:last-child { border-bottom: none; }
  .lhs {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .label {
    font-family: var(--serif);
    font-size: 15.5px;
    color: var(--ink);
  }
  .detail {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--slate);
  }
  .rhs {
    display: flex;
    align-items: baseline;
    gap: 6px;
    white-space: nowrap;
  }
  .value {
    font-family: var(--mono);
    font-size: 14px;
    color: var(--ink);
    letter-spacing: 0.02em;
  }
  .unit {
    font-size: 10.5px;
    letter-spacing: 0.12em;
    color: var(--slate);
    text-transform: uppercase;
  }
</style>
