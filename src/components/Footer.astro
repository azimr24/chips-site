---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="shell footer-inner">
    <span class="meta mono">CHIPS NETWORK · {year}</span>
    <span class="meta mono dot-sep">A2A-NATIVE · LINUX FOUNDATION WG</span>
    <span class="meta mono footer-mails">
      <a href="mailto:eug0212@gmail.com">eug0212@gmail.com</a>
      <span class="footer-sep" aria-hidden="true">·</span>
      <a href="mailto:azimrah14@gmail.com">azimrah14@gmail.com</a>
    </span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--hair);
    background: var(--bg);
  }
  .footer-inner {
    padding: 22px 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 14px;
  }
  .meta {
    font-size: 10px;
    letter-spacing: 0.2em;
    color: var(--slate);
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: none;
  }
  .footer-mails {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    text-transform: none;
    letter-spacing: 0.04em;
    flex-wrap: wrap;
  }
  .footer-mails a {
    color: var(--slate);
    text-decoration: none;
    border-bottom: none;
    transition: color 200ms ease;
  }
  .footer-mails a:hover {
    color: var(--emerald);
  }
  .footer-sep {
    color: var(--hair-2);
    user-select: none;
  }
  .dot-sep {
    flex: 1 1 auto;
    text-align: center;
  }
  @media (max-width: 640px) {
    .footer-inner {
      justify-content: flex-start;
      gap: 10px;
    }
    .dot-sep {
      flex: 0 1 auto;
      text-align: left;
      order: 3;
    }
  }
</style>
