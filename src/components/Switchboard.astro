---
// ─────────────────────────────────────────────────────────────────────────
// Switchboard — Constellation
// A2A handshake network. Bridge at center, consumer agents on a top arc,
// enterprise agents on a bottom arc, always-visible faint spokes form a
// graph, comets sweep along active spokes during handshakes.
// ─────────────────────────────────────────────────────────────────────────

interface NodeDef {
  id: string;
  name: string;
  version: string;
  x: number;
  y: number;
}

const consumers: NodeDef[] = [
  { id: 'chatgpt', name: 'CHATGPT', version: 'v1.1.x', x: 150, y: 112 },
  { id: 'claude', name: 'CLAUDE', version: 'v1.8.x', x: 322, y: 82 },
  { id: 'apple', name: 'APPLE INTEL.', version: 'v1.5.x', x: 482, y: 82 },
  { id: 'perplexity', name: 'PERPLEXITY', version: 'v1.0.x', x: 654, y: 112 },
];

const enterprises: NodeDef[] = [
  { id: 'rei', name: 'REI', version: '.well-known/agent', x: 110, y: 470 },
  { id: 'patagonia', name: 'PATAGONIA', version: '.well-known/agent', x: 232, y: 500 },
  { id: 'backcountry', name: 'BACKCOUNTRY', version: '.well-known/agent', x: 358, y: 510 },
  { id: 'smartwool', name: 'SMARTWOOL', version: '.well-known/agent', x: 478, y: 508 },
  { id: 'moosejaw', name: 'MOOSEJAW', version: '.well-known/agent', x: 604, y: 496 },
  { id: 'outdoor', name: 'OUTDOOR VOICES', version: '.well-known/agent', x: 712, y: 470 },
];

const bridge = { x: 400, y: 290 };

// Hex polygon points (flat-top, radius 7) centered at origin
const HEX_POINTS = '0,-7 6.06,-3.5 6.06,3.5 0,7 -6.06,3.5 -6.06,-3.5';

// Build curved spoke paths (quadratic bezier) from each node to bridge.
// Control point is offset perpendicular to the node→bridge line so each
// spoke curves outward subtly — produces the constellation lens.
function spokePath(nx: number, ny: number, bx: number, by: number): string {
  const mx = (nx + bx) / 2;
  const my = (ny + by) / 2;
  const dx = bx - nx;
  const dy = by - ny;
  const len = Math.hypot(dx, dy) || 1;
  // perpendicular unit vector
  const px = -dy / len;
  const py = dx / len;
  // curve outward — bend amount scales with distance, capped
  const bend = Math.min(28, len * 0.10);
  // Sign of bend: for nodes left of center, curve left; right of center, curve right.
  const sideSign = nx < bx ? -1 : 1;
  const cx = mx + px * bend * sideSign;
  const cy = my + py * bend * sideSign;
  return `M ${nx} ${ny} Q ${cx.toFixed(2)} ${cy.toFixed(2)} ${bx} ${by}`;
}

const consumerSpokes = consumers.map((c) => ({
  id: c.id,
  side: 'consumer' as const,
  d: spokePath(c.x, c.y, bridge.x, bridge.y),
}));
const enterpriseSpokes = enterprises.map((e) => ({
  id: e.id,
  side: 'enterprise' as const,
  d: spokePath(e.x, e.y, bridge.x, bridge.y),
}));
const allSpokes = [...consumerSpokes, ...enterpriseSpokes];
---

<figure class="switchboard" aria-label="Live A2A handshake constellation — consumer agents on a top arc, enterprise agents on a bottom arc, bridge core in center">
  <header class="sb-head">
    <div class="sb-head-l">
      <span class="sb-id mono">A2A · CONSTELLATION</span>
      <span class="sb-id-sub mono">agents.chips.dev</span>
    </div>
    <div class="sb-head-r">
      <span class="sb-tick mono" data-clock>00:00:00 UTC</span>
      <span class="sb-live mono"><span class="sb-pulse"></span>LIVE</span>
    </div>
  </header>

  <div class="sb-stats mono" aria-hidden="true">
    <div class="sb-stat">
      <span class="sb-stat-value" data-stat="handshakes">4,287</span>
      <span class="sb-stat-label">HANDSHAKES / MIN</span>
    </div>
    <div class="sb-stat">
      <span class="sb-stat-value" data-stat="bridge">612</span>
      <span class="sb-stat-label">BRIDGE CALLS</span>
    </div>
    <div class="sb-stat">
      <span class="sb-stat-value">
        <span class="sb-eps-sym">ε</span>
        <span data-stat="epsilon">0.31</span>
        <span class="sb-eps-cap">/ 1.00</span>
      </span>
      <span class="sb-stat-label">DP BUDGET · ANNUAL</span>
    </div>
  </div>

  <svg class="sb-canvas" viewBox="0 0 800 580" preserveAspectRatio="xMidYMid meet" role="presentation">
    <defs>
      <radialGradient id="sb-bridge-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#3e8e5e" stop-opacity="0.45" />
        <stop offset="55%" stop-color="#3e8e5e" stop-opacity="0.12" />
        <stop offset="100%" stop-color="#3e8e5e" stop-opacity="0" />
      </radialGradient>
      <filter id="sb-soft" x="-30%" y="-30%" width="160%" height="160%">
        <feGaussianBlur stdDeviation="0.7" />
      </filter>
    </defs>

    <!-- Ambient concentric grid rings -->
    <g class="sb-grid-rings" aria-hidden="true">
      <circle cx={bridge.x} cy={bridge.y} r="105" />
      <circle cx={bridge.x} cy={bridge.y} r="175" />
      <circle cx={bridge.x} cy={bridge.y} r="250" />
      <circle cx={bridge.x} cy={bridge.y} r="325" />
    </g>

    <!-- Sonar ring (animated on bridge activity) -->
    <circle class="sb-sonar" cx={bridge.x} cy={bridge.y} r="95" />

    <!-- At-rest spokes — always visible network density -->
    <g class="sb-spokes-rest" aria-hidden="true">
      {allSpokes.map((s) => (
        <path class="sb-spoke-rest" d={s.d} data-side={s.side} data-id={s.id} />
      ))}
    </g>

    <!-- Active comet layer (JS appends paths here) -->
    <g class="sb-comets" aria-hidden="true"></g>

    <!-- Bridge instrument panel -->
    <g class="sb-bridge" transform={`translate(${bridge.x}, ${bridge.y})`}>
      <text class="sb-bridge-label mono" y="-78" text-anchor="middle">BRIDGE</text>
      <circle class="sb-bridge-halo" r="58" fill="url(#sb-bridge-glow)" />
      <circle class="sb-bridge-mid" r="22" />
      <circle class="sb-bridge-core" r="7.5" />
      <text class="sb-eps mono" y="36" text-anchor="middle">
        <tspan class="sb-eps-pre">ε ·</tspan>
        <tspan class="sb-eps-num" data-stat-svg="epsilon" dx="3">0.31</tspan>
        <tspan class="sb-eps-cap" dx="3">/ 1.00</tspan>
      </text>
      <line class="sb-instr-rule" x1="-58" x2="58" y1="46" y2="46" />
      <g class="sb-scopes" aria-hidden="true">
        <g transform="translate(0, 60)">
          <text class="sb-scope mono" data-scope="loyalty-tier" x="-44" text-anchor="middle">LOY</text>
          <text class="sb-scope mono" data-scope="purchase-history" x="0" text-anchor="middle">PURCH</text>
          <text class="sb-scope mono" data-scope="size-profile" x="44" text-anchor="middle">SIZE</text>
        </g>
        <g transform="translate(0, 74)">
          <text class="sb-scope mono" data-scope="behavioral-profile" x="-44" text-anchor="middle">BEHAV</text>
          <text class="sb-scope mono" data-scope="category-recent" x="0" text-anchor="middle">CAT</text>
          <text class="sb-scope mono" data-scope="attested-claims" x="44" text-anchor="middle">ATTEST</text>
        </g>
      </g>
    </g>

    <!-- Consumer nodes (top arc) -->
    <g class="sb-nodes sb-nodes-consumer">
      {consumers.map((c) => (
        <g class="sb-node sb-node-consumer" data-side="consumer" data-id={c.id} transform={`translate(${c.x}, ${c.y})`}>
          <circle class="sb-node-ring" r="14" />
          <polygon class="sb-glyph" points={HEX_POINTS} />
          <circle class="sb-glyph-dot" r="1.6" />
          <text class="sb-node-label mono" y="28" text-anchor="middle">{c.name}</text>
          <text class="sb-node-meta mono" y="40" text-anchor="middle">{c.version}</text>
        </g>
      ))}
    </g>

    <!-- Enterprise nodes (bottom arc) -->
    <g class="sb-nodes sb-nodes-enterprise">
      {enterprises.map((e) => (
        <g class="sb-node sb-node-enterprise" data-side="enterprise" data-id={e.id} transform={`translate(${e.x}, ${e.y})`}>
          <circle class="sb-node-ring" r="14" />
          <circle class="sb-glyph" r="7" />
          <circle class="sb-glyph-inner" r="3" />
          <text class="sb-node-label mono" y="-20" text-anchor="middle">{e.name}</text>
          <text class="sb-node-meta mono" y="-32" text-anchor="middle">{e.version}</text>
        </g>
      ))}
    </g>
  </svg>

  <footer class="sb-feed">
    <div class="sb-feed-head mono">
      <span>TS</span>
      <span>ROUTE</span>
      <span>INTENT · SCOPE</span>
      <span>LAT</span>
    </div>
    <ol class="sb-feed-rows" aria-live="polite"></ol>
  </footer>
</figure>

<script>
  type Side = 'consumer' | 'enterprise';
  interface SwitchNode { id: string; name: string; version: string; x: number; y: number; }
  interface SpokeData { id: string; side: Side; d: string; }

  const consumers: SwitchNode[] = [
    { id: 'chatgpt', name: 'CHATGPT', version: 'v1.1.x', x: 150, y: 112 },
    { id: 'claude', name: 'CLAUDE', version: 'v1.8.x', x: 322, y: 82 },
    { id: 'apple', name: 'APPLE INTEL.', version: 'v1.5.x', x: 482, y: 82 },
    { id: 'perplexity', name: 'PERPLEXITY', version: 'v1.0.x', x: 654, y: 112 },
  ];
  const enterprises: SwitchNode[] = [
    { id: 'rei', name: 'REI', version: '.well-known', x: 110, y: 470 },
    { id: 'patagonia', name: 'PATAGONIA', version: '.well-known', x: 232, y: 500 },
    { id: 'backcountry', name: 'BACKCOUNTRY', version: '.well-known', x: 358, y: 510 },
    { id: 'smartwool', name: 'SMARTWOOL', version: '.well-known', x: 478, y: 508 },
    { id: 'moosejaw', name: 'MOOSEJAW', version: '.well-known', x: 604, y: 496 },
    { id: 'outdoor', name: 'OUTDOOR VOICES', version: '.well-known', x: 712, y: 470 },
  ];
  const BRIDGE = { x: 400, y: 290 };

  const intents = [
    'ski-layering', 'winter-jacket', 'trail-runner', 'baselayer', 'rain-shell',
    'down-bag', 'fit-check', 'gift-recs', 'wool-socks', 'pack-fit',
    'glove-pair', 'sleep-system', 'mid-layer', 'hardshell',
  ];
  const scopes = [
    'loyalty-tier', 'purchase-history', 'size-profile',
    'behavioral-profile', 'category-recent', 'attested-claims',
  ];

  const SVG_NS = 'http://www.w3.org/2000/svg';

  function rand<T>(arr: T[]): T { return arr[Math.floor(Math.random() * arr.length)] as T; }
  function jitter(base: number, spread: number) { return base + (Math.random() - 0.5) * spread; }
  function pad(n: number, w = 2) { return n.toString().padStart(w, '0'); }
  function fmtInt(n: number): string { return n.toLocaleString('en-US'); }

  function spokeD(nx: number, ny: number): string {
    const bx = BRIDGE.x, by = BRIDGE.y;
    const mx = (nx + bx) / 2;
    const my = (ny + by) / 2;
    const dx = bx - nx;
    const dy = by - ny;
    const len = Math.hypot(dx, dy) || 1;
    const px = -dy / len, py = dx / len;
    const bend = Math.min(28, len * 0.10);
    const sideSign = nx < bx ? -1 : 1;
    const cx = mx + px * bend * sideSign;
    const cy = my + py * bend * sideSign;
    return `M ${nx} ${ny} Q ${cx.toFixed(2)} ${cy.toFixed(2)} ${bx} ${by}`;
  }

  function init(root: HTMLElement) {
    const svg = root.querySelector('.sb-canvas') as SVGSVGElement | null;
    const cometsLayer = root.querySelector('.sb-comets') as SVGGElement | null;
    const bridgeEl = root.querySelector('.sb-bridge') as SVGGElement | null;
    const sonar = root.querySelector('.sb-sonar') as SVGCircleElement | null;
    const feedRows = root.querySelector('.sb-feed-rows') as HTMLOListElement | null;
    const clockEl = root.querySelector('[data-clock]') as HTMLElement | null;
    const statHandshakes = root.querySelector('[data-stat="handshakes"]') as HTMLElement | null;
    const statBridge = root.querySelector('[data-stat="bridge"]') as HTMLElement | null;
    const statEpsilon = root.querySelector('[data-stat="epsilon"]') as HTMLElement | null;
    const statEpsilonSvg = root.querySelector('[data-stat-svg="epsilon"]') as SVGTSpanElement | null;

    if (!svg || !cometsLayer || !bridgeEl || !sonar || !feedRows) return;

    // Synthetic clock & stats
    let virtualNow = Date.now() - 3 * 3600 * 1000 + Math.floor(Math.random() * 8 * 3600 * 1000);
    let handshakeCount = 4287 + Math.floor(Math.random() * 200);
    let bridgeCallCount = 612 + Math.floor(Math.random() * 30);
    let epsilon = 0.31 + Math.random() * 0.05;

    function paintClock() {
      if (!clockEl) return;
      const d = new Date(virtualNow);
      clockEl.textContent = `${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())} UTC`;
    }
    function paintStats() {
      if (statHandshakes) statHandshakes.textContent = fmtInt(handshakeCount);
      if (statBridge) statBridge.textContent = fmtInt(bridgeCallCount);
      const epsStr = epsilon.toFixed(3);
      if (statEpsilon) statEpsilon.textContent = epsStr;
      if (statEpsilonSvg) statEpsilonSvg.textContent = epsStr;
    }
    paintClock();
    paintStats();

    const clockTimer = setInterval(() => {
      virtualNow += 1000;
      paintClock();
    }, 1000);

    // Resolve node coordinates by id
    function nodeById(side: Side, id: string): SwitchNode | undefined {
      const arr = side === 'consumer' ? consumers : enterprises;
      return arr.find((n) => n.id === id);
    }

    function flashNode(side: Side, id: string, delay = 0) {
      const node = root.querySelector<SVGGElement>(`.sb-node[data-side="${side}"][data-id="${id}"]`);
      if (!node) return;
      setTimeout(() => {
        node.classList.add('sb-node-active');
        setTimeout(() => node.classList.remove('sb-node-active'), 700);
      }, delay);
    }

    function flashSpokeRest(side: Side, id: string, delay = 0) {
      const spoke = root.querySelector<SVGPathElement>(`.sb-spoke-rest[data-side="${side}"][data-id="${id}"]`);
      if (!spoke) return;
      setTimeout(() => {
        spoke.classList.add('sb-spoke-bright');
        setTimeout(() => spoke.classList.remove('sb-spoke-bright'), 900);
      }, delay);
    }

    function flashScopeTag(scope: string, delay = 0) {
      const tag = root.querySelector<SVGTextElement>(`.sb-scope[data-scope="${scope}"]`);
      if (!tag) return;
      setTimeout(() => {
        tag.classList.add('sb-scope-active');
        setTimeout(() => tag.classList.remove('sb-scope-active'), 500);
      }, delay);
    }

    function pulseSonar(strong = false) {
      sonar.classList.remove('sb-sonar-firing', 'sb-sonar-firing-strong');
      // Force reflow so re-adding the class restarts the animation
      void sonar.getBoundingClientRect();
      sonar.classList.add(strong ? 'sb-sonar-firing-strong' : 'sb-sonar-firing');
      setTimeout(
        () => sonar.classList.remove('sb-sonar-firing', 'sb-sonar-firing-strong'),
        strong ? 900 : 600,
      );
    }

    function pulseBridge(strong = false) {
      bridgeEl.classList.add(strong ? 'sb-bridge-strong' : 'sb-bridge-active');
      setTimeout(
        () => bridgeEl.classList.remove('sb-bridge-active', 'sb-bridge-strong'),
        strong ? 700 : 420,
      );
    }

    function drawComet(node: SwitchNode, isBridgeFan = false, scopeLabel?: string) {
      const d = spokeD(node.x, node.y);

      const path = document.createElementNS(SVG_NS, 'path');
      path.setAttribute('d', d);
      path.setAttribute('fill', 'none');
      path.setAttribute('pathLength', '100');
      path.setAttribute('class', isBridgeFan ? 'sb-comet sb-comet-fan' : 'sb-comet');
      cometsLayer.appendChild(path);

      // Trail (lower-opacity dash that lingers slightly behind)
      const trail = document.createElementNS(SVG_NS, 'path');
      trail.setAttribute('d', d);
      trail.setAttribute('fill', 'none');
      trail.setAttribute('pathLength', '100');
      trail.setAttribute('class', isBridgeFan ? 'sb-comet-trail sb-comet-trail-fan' : 'sb-comet-trail');
      cometsLayer.appendChild(trail);

      // Optional scope label that rides at midpath (bridge-fan only)
      let token: SVGGElement | null = null;
      if (isBridgeFan && scopeLabel) {
        const midX = (node.x + BRIDGE.x) / 2;
        const midY = (node.y + BRIDGE.y) / 2;
        token = document.createElementNS(SVG_NS, 'g');
        token.setAttribute('class', 'sb-scope-token');
        token.setAttribute('transform', `translate(${midX.toFixed(1)}, ${midY.toFixed(1)})`);
        const tokenText = document.createElementNS(SVG_NS, 'text');
        tokenText.setAttribute('text-anchor', 'middle');
        tokenText.setAttribute('class', 'mono');
        tokenText.textContent = scopeLabel;
        token.appendChild(tokenText);
        cometsLayer.appendChild(token);
      }

      // Remove after animation completes
      setTimeout(() => {
        path.remove();
        trail.remove();
        if (token) token.remove();
      }, 1500);
    }

    function addFeedRow(opts: {
      consumer: SwitchNode;
      enterprise: SwitchNode;
      intent: string;
      scope: string;
      latency: number;
      kind: 'handshake' | 'bridge';
    }) {
      virtualNow += Math.floor(jitter(900, 700));
      const d = new Date(virtualNow);
      const ts = `${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}:${pad(d.getUTCSeconds())}.${pad(d.getUTCMilliseconds(), 3)}`;

      const latTier =
        opts.latency < 300 ? 'fast' :
        opts.latency < 600 ? 'normal' : 'slow';

      const li = document.createElement('li');
      li.className = `sb-row sb-row-${opts.kind}`;

      const tsEl = document.createElement('span');
      tsEl.className = 'sb-ts mono';
      tsEl.textContent = ts;

      const routeEl = document.createElement('span');
      routeEl.className = 'sb-route mono';
      const arrowEl = document.createElement('span');
      arrowEl.className = 'sb-arrow';
      arrowEl.textContent = opts.kind === 'bridge' ? ' ⇉ ' : ' → ';
      routeEl.append(
        document.createTextNode(opts.consumer.name),
        arrowEl,
        document.createTextNode(opts.enterprise.name),
      );

      const scopeEl = document.createElement('span');
      scopeEl.className = 'sb-scope-col mono';
      scopeEl.append(document.createTextNode(opts.intent));
      const scopeDim = document.createElement('span');
      scopeDim.className = 'sb-scope-dim';
      scopeDim.textContent = ` · ${opts.scope}`;
      scopeEl.append(scopeDim);

      const latEl = document.createElement('span');
      latEl.className = `sb-lat mono sb-lat-${latTier}`;
      latEl.append(document.createTextNode(String(opts.latency)));
      const latUnit = document.createElement('span');
      latUnit.className = 'sb-lat-unit';
      latUnit.textContent = 'ms';
      latEl.append(latUnit);

      li.append(tsEl, routeEl, scopeEl, latEl);
      feedRows.prepend(li);

      // Trim — sync snapshot, never a while loop on async removal.
      const overflow = Array.from(feedRows.children).slice(6);
      for (const el of overflow) {
        if (el.classList.contains('sb-row-out')) continue;
        el.classList.add('sb-row-out');
        setTimeout(() => el.remove(), 400);
      }
      requestAnimationFrame(() => li.classList.add('sb-row-in'));
    }

    let counter = 0;
    let nextTimer: ReturnType<typeof setTimeout> | null = null;
    const stagedTimers: Set<ReturnType<typeof setTimeout>> = new Set();
    function stage(fn: () => void, delay: number) {
      const t = setTimeout(() => {
        stagedTimers.delete(t);
        fn();
      }, delay);
      stagedTimers.add(t);
      return t;
    }
    function clearStaged() {
      for (const t of stagedTimers) clearTimeout(t);
      stagedTimers.clear();
    }

    function scheduleNext(delay: number) {
      if (document.hidden) return;
      nextTimer = setTimeout(() => {
        nextTimer = null;
        fireHandshake();
      }, delay);
    }

    function fireHandshake() {
      if (document.hidden) return;
      const isBridge = counter > 0 && counter % 5 === 0;
      const consumer = rand(consumers);
      const enterprise = rand(enterprises);
      const intent = rand(intents);
      const scope = rand(scopes);
      const latency = Math.round(jitter(380, 380));

      // Tick stats
      handshakeCount += 1;
      epsilon = Math.min(1.0, epsilon + 0.0008 + Math.random() * 0.0012);
      paintStats();

      // Stage 1 — Consumer ignites
      flashNode('consumer', consumer.id, 0);
      flashSpokeRest('consumer', consumer.id, 0);
      drawComet(consumer);

      // Stage 2 — Bridge arrival
      stage(() => {
        pulseSonar(false);
        pulseBridge(false);
        flashScopeTag(scope);
      }, 480);

      // Stage 3 — Enterprise receives
      stage(() => {
        drawComet(enterprise);
        flashSpokeRest('enterprise', enterprise.id);
      }, 540);
      stage(() => flashNode('enterprise', enterprise.id), 1020);

      // Feed row (logged with original latency)
      stage(() => addFeedRow({ consumer, enterprise, intent, scope, latency, kind: 'handshake' }), 460);

      // Bridge fan-out — every 5th event
      if (isBridge) {
        bridgeCallCount += 1;

        const others = enterprises.filter((e) => e.id !== enterprise.id);
        // Shuffle, pick two
        for (let i = others.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [others[i], others[j]] = [others[j]!, others[i]!];
        }
        const e2 = others[0]!;
        const e3 = others[1]!;
        const scope2 = rand(scopes.filter((s) => s !== scope));
        const scope3 = rand(scopes.filter((s) => s !== scope && s !== scope2));

        // Strong sonar + bridge pulse on fan moment
        stage(() => pulseSonar(true), 540);
        stage(() => pulseBridge(true), 540);

        stage(() => {
          drawComet(e2, true, scope2);
          flashSpokeRest('enterprise', e2.id);
          flashScopeTag(scope2);
        }, 620);
        stage(() => flashNode('enterprise', e2.id), 1100);

        stage(() => {
          drawComet(e3, true, scope3);
          flashSpokeRest('enterprise', e3.id);
          flashScopeTag(scope3);
        }, 740);
        stage(() => flashNode('enterprise', e3.id), 1220);

        stage(() => addFeedRow({
          consumer, enterprise: e2, intent,
          scope: scope2, latency: Math.round(jitter(520, 280)),
          kind: 'bridge',
        }), 660);
        stage(() => addFeedRow({
          consumer, enterprise: e3, intent,
          scope: scope3, latency: Math.round(jitter(480, 260)),
          kind: 'bridge',
        }), 780);
      }

      counter++;
      const nextDelay = isBridge ? jitter(2600, 600) : jitter(1700, 700);
      scheduleNext(nextDelay);
    }

    // Pause on hidden tab
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        if (nextTimer != null) {
          clearTimeout(nextTimer);
          nextTimer = null;
        }
        clearStaged();
      } else if (nextTimer == null) {
        scheduleNext(500);
      }
    });

    // Boot
    scheduleNext(700);

    // Cleanup on detach (defensive — Astro static site usually doesn't detach,
    // but if Astro view transitions are added later this is safe)
    return () => {
      clearInterval(clockTimer);
      if (nextTimer != null) clearTimeout(nextTimer);
      clearStaged();
    };
  }

  function boot() {
    document.querySelectorAll<HTMLElement>('.switchboard').forEach(init);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }
</script>

<style>
  /* ─────────────────── Container ─────────────────── */
  .switchboard {
