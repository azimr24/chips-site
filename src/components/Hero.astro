---
import StatusPill from './StatusPill.astro';

interface Props {
  eyebrow: string;
  kicker?: string;
}

const { eyebrow, kicker = 'CHIPS · V0 · 2026' } = Astro.props;
---

<section class="hero">
  <div class="shell">
    <div class="hero-meta">
      <span class="kicker mono">{kicker}</span>
      <StatusPill kind="emerald" pulse>NETWORK · LIVE</StatusPill>
    </div>

    <span class="eyebrow mono">{eyebrow}</span>

    <h1 class="headline">
      <slot name="headline" />
    </h1>

    <div class="sub">
      <slot name="sub" />
    </div>

    <div class="ctas">
      <slot name="ctas" />
    </div>

    <div class="strip">
      <slot name="strip" />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 56px 0 80px;
    border-top: none;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-bottom: 56px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--hair);
  }
  .kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--slate);
  }
  .eyebrow {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--emerald);
    display: block;
    margin-bottom: 28px;
  }
  .headline {
    font-family: var(--serif);
    font-size: var(--fs-display);
    line-height: 0.98;
    letter-spacing: -0.026em;
    font-weight: 400;
    color: var(--ink);
    margin: 0 0 36px;
    max-width: 18ch;
  }
  .headline :global(em) {
    font-style: italic;
    color: var(--emerald);
  }
  .headline :global(.dot) {
    color: var(--emerald);
    font-style: normal;
  }
  .sub {
    font-family: var(--serif);
    font-size: var(--fs-lede);
    line-height: 1.45;
    color: var(--slate);
    max-width: 62ch;
    margin: 0 0 40px;
  }
  .sub :global(p) {
    margin: 0 0 1em;
  }
  .sub :global(p:last-child) {
    margin-bottom: 0;
  }
  .sub :global(em) {
    font-style: italic;
    color: var(--emerald);
  }
  .ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 64px;
  }
  .strip {
    border-top: 1px solid var(--hair);
    border-bottom: 1px solid var(--hair);
    padding: 24px 0;
  }
</style>
