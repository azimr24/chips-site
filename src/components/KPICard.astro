---
interface Props {
  label: string;
  value: string;
  suffix?: string;
  detail?: string;
}

const { label, value, suffix, detail } = Astro.props;
---

<div class="kpi">
  <span class="mono-label">{label}</span>
  <div class="value-row">
    <span class="value">{value}</span>
    {suffix && <span class="suffix">{suffix}</span>}
  </div>
  {detail && <span class="detail">{detail}</span>}
</div>

<style>
  .kpi {
    padding: 26px 24px 22px;
    border-right: 1px solid var(--hair);
    min-height: 140px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 14px;
  }
  .kpi:last-child {
    border-right: none;
  }
  .mono-label {
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--slate);
  }
  .value-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .value {
    font-family: var(--serif);
    font-size: 40px;
    line-height: 1;
    letter-spacing: -0.022em;
    color: var(--ink);
  }
  .suffix {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--slate);
    text-transform: uppercase;
  }
  .detail {
    font-family: var(--serif);
    font-style: italic;
    font-size: 14px;
    color: var(--slate);
    line-height: 1.35;
  }
  @media (max-width: 700px) {
    .kpi {
      border-right: none;
      border-bottom: 1px solid var(--hair);
      min-height: unset;
      padding: 22px 20px 20px;
    }
    .kpi:last-child { border-bottom: none; }
    .value { font-size: 34px; }
  }
</style>
