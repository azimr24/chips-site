---
import BrandWordmark from './BrandWordmark.astro';

const CAL_LINK = 'https://cal.com/eugene-ye';
---

<header class="topbar">
  <div class="shell topbar-inner">
    <BrandWordmark size="md" href="/" />

    <div class="topbar-right">
      <span class="status mono" aria-hidden="true">
        <span class="status-dot"></span>NETWORK · LIVE
      </span>
      <a class="cta mono" href={CAL_LINK} target="_blank" rel="noopener">
        <span>Schedule a call</span>
        <span class="cta-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in oklab, var(--bg) 92%, transparent);
    backdrop-filter: blur(10px) saturate(108%);
    -webkit-backdrop-filter: blur(10px) saturate(108%);
    border-bottom: 1px solid var(--hair);
  }
  .topbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 0 16px;
    gap: 24px;
  }
  .topbar-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    letter-spacing: 0.22em;
    color: var(--slate);
    text-transform: uppercase;
  }
  .status-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--emerald);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--emerald) 18%, transparent);
    animation: nav-pulse 1.8s ease-in-out infinite;
  }
  @keyframes nav-pulse {
    0%, 100% { opacity: 0.5; transform: scale(0.85); }
    50%      { opacity: 1; transform: scale(1); }
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
    text-decoration: none;
    padding: 9px 14px 8px;
    border: 1px solid var(--ink);
    border-radius: 3px;
    background: var(--ink);
    color: var(--bg);
    transition: background 200ms ease, transform 200ms ease, border-color 200ms ease;
  }
  .cta:hover {
    background: transparent;
    color: var(--ink);
  }
  .cta:hover .cta-arrow {
    transform: translateX(3px);
  }
  .cta-arrow {
    transition: transform 200ms ease;
    font-family: var(--mono);
  }

  @media (max-width: 640px) {
    .status { display: none; }
    .cta { padding: 8px 11px 7px; font-size: 10.5px; letter-spacing: 0.12em; }
    .topbar-inner { padding: 14px 0 13px; }
  }
</style>
