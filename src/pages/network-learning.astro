---
import Doc from '../layouts/Doc.astro';
import FeatureRow from '../components/FeatureRow.astro';
import Callout from '../components/Callout.astro';
import KPICard from '../components/KPICard.astro';
import MonoLabel from '../components/MonoLabel.astro';

const loops = [
  {
    id: 'I',
    name: 'Per-consumer state',
    level: 'A',
    storage: 'Enterprise CDP',
    timescale: 'Relationship lifetime',
    desc: 'The enterprise agent observes one individual across multiple sessions. Maya rejected the synthetic insulator three weeks ago, asked about wool baselayers, abandoned. Next session: REI opens with "last time you were looking at mid-layers and seemed interested in merino — is that still on your mind?"',
  },
  {
    id: 'II',
    name: 'Per-SKU behavioral enrichment',
    level: 'A',
    storage: 'Enterprise PIM',
    timescale: 'Per-product, all sessions',
    desc: 'Every time a SKU surfaces, the agent observes who reacts well, which questions it elicits ("does this run small"), which objections it raises, which comparisons consumers draw. The SKU\'s behavioral metadata gets richer than what the merchant authored.',
  },
  {
    id: 'III',
    name: 'Per-enterprise policy refinement',
    level: 'A',
    storage: 'Policy YAML + optional fine-tuned model',
    timescale: 'Across all sessions',
    desc: 'When to ask clarifying questions vs. recommend. When to bridge vs. work with what you have. How to phrase objection responses. Each session reveals which patterns produce purchases, repeats, low return rates — vs. abandons, returns, complaints.',
  },
  {
    id: 'IV',
    name: 'Cross-enterprise network learning',
    level: 'B',
    storage: 'Chips · DP-aggregated',
    timescale: 'All enterprises participating',
    desc: 'When every Chips-network outdoor retailer observes patterns like "consumers planning ski trips ask about layering in shell → mid → base order; conversion-maximizing sequence confirms shell intent first" — that\'s collective signal nobody can learn alone.',
  },
  {
    id: 'V',
    name: 'Bridge utility learning',
    level: 'B',
    storage: 'Chips · bridge runtime',
    timescale: 'All bridge calls',
    desc: 'The bridge runtime sees every cross-enterprise query: scope, context, return, downstream impact on the calling enterprise\'s reasoning, eventual conversion outcome. Over time predicts utility, suggests queries, optimizes scope choice.',
  },
];
---

<Doc
  title="Network learning — the moat that compounds"
  description="Five learning loops, two levels. Level A stays at the enterprise. Level B aggregates across the network under differential privacy. The bridge is the moat people see; network learning is the moat that compounds."
  pageLabel="NETWORK LEARNING"
  eyebrow="06.1 §5 · THE MOAT THAT COMPOUNDS"
  heading={`Five loops.<br/><em>Two</em> levels.<br/>One <em>compounding</em> network<span class="dot">.</span>`}
  lede="Every conversation between a consumer agent and a Chips-hosted enterprise agent generates structured signal at five distinct timescales, with different storage locations, different consent surfaces, and different competitive implications. This is the compounding moat."
>
  <section class="loops">
    <div class="section-head">
      <MonoLabel tone="emerald">§5.1 · THE FIVE LOOPS</MonoLabel>
      <span class="section-rule"></span>
    </div>

    <table class="loop-table">
      <thead>
        <tr>
          <th class="col-id">Loop</th>
          <th class="col-name">Name</th>
          <th class="col-level">Level</th>
          <th class="col-storage">Storage</th>
          <th class="col-timescale">Compounds across</th>
        </tr>
      </thead>
      <tbody>
        {loops.map((loop) => (
          <tr>
            <td class="col-id mono">{loop.id}</td>
            <td class="col-name">
              <strong>{loop.name}</strong>
              <span class="desc">{loop.desc}</span>
            </td>
            <td class="col-level">
              <span class={`badge badge-${loop.level === 'A' ? 'a' : 'b'}`}>{loop.level}</span>
            </td>
            <td class="col-storage mono">{loop.storage}</td>
            <td class="col-timescale mono">{loop.timescale}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <FeatureRow number="§5.2" label="THE DISTINCTION" heading="Level A is the table stakes. Level B is the moat.">
    <p>
      <em>Level A</em> is what each enterprise learns about its own customers, products, and policy. Any
      enterprise running a competent A2A agent on Bedrock or Foundry gets Level A automatically. No structural
      Chips moat at this level. The enterprise SDK ships the event-extractor instrumentation so Level A works
      for BYO-runtime enterprises too — Chips runs the pipeline, the data terminates at the enterprise's own
      systems.
    </p>
    <p>
      <em>Level B</em> is what the network learns collectively. An enterprise that builds its agent solo gets
      none of this. An enterprise on Chips gets Level B as a <em>dividend on network participation</em>. This is
      the actual compounding moat — far more than the bridge alone. The bridge is the consent-mediated context
      primitive (legible, simple to explain); Level B is the privacy-mediated wisdom primitive (deeper, takes
      time to communicate but harder to dislodge).
    </p>
  </FeatureRow>

  <FeatureRow number="§5.3" label="HYPERSCALER GAP" heading="Why Bedrock and Foundry structurally cannot replicate Level B.">
    <p>
      Bedrock and Foundry could in principle aggregate cross-enterprise signal — they host enterprise agents.
      They can't credibly do it because their commercial relationships compete with the enterprises they'd
      aggregate from.
    </p>
    <p>
      <em>REI won't trust AWS with their conversion patterns when AWS is simultaneously selling cloud services
      to the rest of the retail world and operating Amazon's own retail business.</em> Chips can be the broker
      because Chips has no enterprise of its own to protect.
    </p>
  </FeatureRow>

  <FeatureRow number="§5.4" label="DP MECHANICS" heading="Differential privacy is the math that makes Level B viable.">
    <p>
      The challenge: REI does not want Backcountry to know which products are converting for them, and
      vice versa. Network learning that exposes per-enterprise competitive intel kills participation
      immediately.
    </p>
    <p>
      Every learnable signal extracted from a conversation carries a sensitivity bound. Chips aggregates
      across enterprises with <em>calibrated Gaussian / Laplace noise</em> such that no single enterprise's
      contribution to any output is reverse-engineerable. Privacy budget (ε) bounded per release;
      consumption tracked across the year.
    </p>
    <p>
      Outputs are population-level: <em>"consumers asking about ski layering have a 38% conversion rate when
      offered mid-layer + glove pairing first"</em> — never <em>"REI's customer X bought Y"</em> and never
      <em>"Backcountry sees a 42% conversion on synthetic insulators."</em>
    </p>
    <p>
      Technique is mature: equivalent to what Apple does for on-device language model training, what the
      Census Bureau does for redistricting tables. <em>Applying it to commerce agent learning is the novel
      application; the math is settled.</em> Audit pipeline + external DP review baked into the release cycle.
    </p>
  </FeatureRow>

  <FeatureRow number="§5.5" label="COLD START" heading="Day 1 above what a solo agent achieves at month 6.">
    <p>
      With Level B priors baked in, the freshly onboarded enterprise's agent already operates above what a
      solo Bedrock agent achieves at six months. It inherits the network's accumulated objection-handling
      patterns, intent taxonomies, conversion-by-context priors, optimal clarifying-question sequences,
      complementary-product associations.
    </p>
    <p>
      Concretely, on the very first conversation:
    </p>
    <ul>
      <li>It knows consumers planning ski trips ask about layering in <em>shell → mid → base</em> order.</li>
      <li>It knows price objections on synthetic insulators convert 22% better with a <em>"complete your kit"</em> framing than a flat discount.</li>
      <li>It knows bridge calls to outdoor-retail competitors are worth invoking on average X% of the time and which conversation contexts most predict utility.</li>
      <li>It knows returns in the category cluster around fit issues 65% of the time, so the optimal clarifying question is fit-related.</li>
    </ul>
    <p>
      <em>None of this is "the enterprise's data" — it's network-derived priors with formal privacy guarantees.</em>
      The enterprise's own Loop 1–3 signal layers on top over time.
    </p>
  </FeatureRow>

  <Callout variant="quote">
    <p>
      The cold-start argument from prior briefs was <em>"we bootstrap the consumer's context."</em>
    </p>
    <p>
      The actual cold-start argument is <strong>"we bootstrap both the consumer's context AND the agent's
      behavior"</strong> — the second piece being far harder for any competitor to replicate.
    </p>
  </Callout>

  <section class="consent">
    <div class="section-head">
      <MonoLabel tone="emerald">§5.6 · CONSUMER CONSENT FOR NETWORK CONTRIBUTION</MonoLabel>
      <span class="section-rule"></span>
    </div>

    <div class="consent-grid">
      <KPICard label="DEFAULT DISCLOSURE" value="A·B·C" detail="(A) Better recommendations for you · (B) Bridge context across retailers · (C) Contribute to anonymized industry patterns" />
      <KPICard label="OPT-OUT GRANULARITY" value="PER" suffix="CHANNEL" detail="Consumer can opt out of any of (a)/(b)/(c) by saying so in conversation" />
      <KPICard label="EPSILON BUDGET" value="ε ≤ 1" suffix="ANNUAL" detail="Per-release tracking · external DP audit · public quarterly transparency report" />
      <KPICard label="REGULATOR SURFACE" value="ART. 22" suffix="HOOK" detail="Explainability hook on every prior consumed · GDPR + EU AI Act ready" />
    </div>
  </section>
</Doc>

<style>
  section {
    margin-bottom: 64px;
  }
  .loop-table {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--hair);
    background: color-mix(in oklab, var(--bg-soft) 60%, transparent);
    margin-bottom: 32px;
  }
  .loop-table thead th {
    text-align: left;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--slate);
    padding: 16px 20px;
    border-bottom: 1px solid var(--hair);
    font-weight: 500;
  }
  .loop-table tbody td {
    padding: 22px 20px;
    border-bottom: 1px solid var(--hair);
    vertical-align: top;
    font-family: var(--serif);
    font-size: 15px;
    line-height: 1.4;
  }
  .loop-table tbody tr:last-child td { border-bottom: none; }
  .col-id {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--emerald);
    letter-spacing: 0.16em;
    width: 70px;
  }
  .col-name strong {
    font-family: var(--serif);
    font-size: 17px;
    font-weight: 500;
    color: var(--ink);
    display: block;
    margin-bottom: 6px;
    letter-spacing: -0.005em;
  }
  .col-name .desc {
    font-family: var(--serif);
    font-size: 14.5px;
    color: var(--slate);
    line-height: 1.4;
    display: block;
    max-width: 60ch;
  }
  .col-level { width: 60px; }
  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0;
  }
  .badge-a {
    background: var(--bg-soft);
    color: var(--ink);
    border: 1px solid var(--hair-2);
  }
  .badge-b {
    background: var(--emerald-soft);
    color: var(--emerald-deep);
    border: 1px solid var(--emerald);
  }
  .col-storage,
  .col-timescale {
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.06em;
    color: var(--slate);
    width: 200px;
  }
  .consent-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border: 1px solid var(--hair);
  }
  @media (max-width: 1000px) {
    .col-storage, .col-timescale { display: none; }
  }
  @media (max-width: 700px) {
    .loop-table { font-size: 14px; }
    .loop-table thead th { padding: 12px 14px; }
    .loop-table tbody td { padding: 16px 14px; }
    .consent-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 500px) {
    .consent-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
