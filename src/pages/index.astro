---
import Base from '../layouts/Base.astro';
import Switchboard from '../components/Switchboard.astro';

const CAL = 'https://cal.com/eugene-ye';
---

<Base
  title="Chips — Invisible commerce infrastructure for the agentic web."
  description="A protocol the consumer never sees. Invisible commerce infrastructure for the agentic web."
>
  <!-- ACT I — Hero + Switchboard -->
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="line-mark" aria-hidden="true"></span>
          <span class="eyebrow mono">INVISIBLE COMMERCE INFRASTRUCTURE · A2A · v0.6.1</span>
        </div>

        <h1 class="headline">
          A protocol<br />the consumer<br /><em>never</em> sees<span class="dot">.</span>
        </h1>

        <p class="sub">
          Invisible commerce infrastructure for the agentic web.<br />
          Watching it run<span class="watching-arrow" aria-hidden="true"> →</span>
        </p>

        <div class="hero-ctas">
          <a class="btn btn-primary" href={CAL} target="_blank" rel="noopener">
            <span>Schedule a call</span>
            <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
          <span class="mail-pair">
            <a class="mail-link mono" href="mailto:eugene@connectchips.xyz">eugene@connectchips.xyz</a>
            <span class="mail-sep" aria-hidden="true">·</span>
            <a class="mail-link mono" href="mailto:azim@connectchips.xyz">azim@connectchips.xyz</a>
          </span>
        </div>

        <div class="hero-trace mono" aria-hidden="true">
          <span class="trace-mark">▍</span>
          <span class="trace-text" data-trace>trace · jwt:RS256 → bridge.grant:always → task:input-required → settle:rebate</span>
        </div>
      </div>

      <aside class="hero-switchboard" aria-label="Live A2A traffic between consumer agents and Chips-hosted enterprise agents">
        <Switchboard />
      </aside>
    </div>
  </section>

  <!-- ACT I.5 — Three Pillars strip (legend for the constellation above) -->
  <section class="pillars-strip" aria-label="The three primitives Chips ships">
    <div class="shell pillars-grid">
      <article class="pillar">
        <span class="pillar-id mono"><span class="roman">I</span> · RUNTIME</span>
        <h3 class="pillar-name">Hosted A2A<span class="dot">.</span></h3>
        <p class="pillar-spec mono">multi-tenant · BYO LLM · 11 JSON-RPC</p>
      </article>
      <article class="pillar">
        <span class="pillar-id mono"><span class="roman">II</span> · BRIDGE</span>
        <h3 class="pillar-name">Cross-enterprise context<span class="dot">.</span></h3>
        <p class="pillar-spec mono">consent-mediated · audit-logged · scope vocab</p>
      </article>
      <article class="pillar">
        <span class="pillar-id mono"><span class="roman">III</span> · NETWORK</span>
        <h3 class="pillar-name">Level B priors<span class="dot">.</span></h3>
        <p class="pillar-spec mono">DP-aggregated · ε-bounded · compounding</p>
      </article>
    </div>
  </section>

  <!-- ACT II — Manifesto -->
  <section class="manifesto">
    <div class="shell manifesto-inner">
      <span class="manifesto-mark mono">§ MANIFESTO</span>

      <p class="stanza">
        The page web was wired for surveillance.<br />
        The agentic web is wired for <em>context</em>.
      </p>

      <p class="stanza">
        The bridge is the moat people see.<br />
        Network learning is the moat that <em>compounds</em>.
      </p>

      <p class="stanza">
        The consumer never signs up.<br />
        Never sees a screen.<br />
        That&rsquo;s the protocol.
      </p>

      <div class="manifesto-corner mono" aria-hidden="true">
        <span>00 · FIRST PRINCIPLES</span>
        <span>chips.dev / v0.6.1</span>
      </div>
    </div>
  </section>

  <!-- ACT III — Closer -->
  <section class="closer">
    <div class="shell closer-inner">
      <div class="closer-meta mono">
        <span class="closer-dot"></span>
        <span>ENROLLING THE LAUNCH COHORT</span>
        <span class="closer-meta-sep">·</span>
        <span>OUTDOOR · BEAUTY · HOME</span>
      </div>

      <h2 class="closer-headline">
        Let&rsquo;s build<br />
        the <em>agentic</em> web<span class="dot">.</span>
      </h2>

      <p class="closer-sub">Founders take every call.</p>

      <div class="closer-ctas">
        <a class="btn btn-primary btn-light" href={CAL} target="_blank" rel="noopener">
          <span>Schedule a call</span>
          <span class="btn-arrow" aria-hidden="true">→</span>
        </a>
        <span class="mail-pair mail-pair-light">
          <a class="closer-mail mono" href="mailto:eugene@connectchips.xyz">eugene@connectchips.xyz</a>
          <span class="mail-sep" aria-hidden="true">·</span>
          <a class="closer-mail mono" href="mailto:azim@connectchips.xyz">azim@connectchips.xyz</a>
        </span>
      </div>

      <div class="closer-grid" aria-hidden="true"></div>
    </div>
  </section>
</Base>

<script>
  // Hero trace cycling — crossfade through prepared A2A traces every ~4s.
  // Uses textContent (safe DOM), single setInterval, pause on hidden tab.
  const traces = [
    'trace · jwt:RS256 → bridge.grant:always → task:input-required → settle:rebate',
    'trace · oidc.email → bridge.query:purchase-history → task:completed · 287µs',
    'trace · a2a.handshake → consent.granted:outdoor → priors:loaded · 47ms',
    'trace · TASK_STATE_AUTH_REQUIRED → bridge.fan:3 → settle.shared',
    'trace · runtime:tenant=rei → policy.yaml#L142 → outcome.purchase',
  ];

  function bootTrace() {
    const el = document.querySelector<HTMLElement>('[data-trace]');
    if (!el) return;
    let idx = 0;
    let timer: ReturnType<typeof setInterval> | null = null;

    function cycle() {
      if (document.hidden) return;
      el.classList.add('trace-fading');
      setTimeout(() => {
        idx = (idx + 1) % traces.length;
        el.textContent = traces[idx]!;
        el.classList.remove('trace-fading');
      }, 320);
    }

    function start() {
      if (timer != null) return;
      timer = setInterval(cycle, 4200);
    }
    function stop() {
      if (timer != null) { clearInterval(timer); timer = null; }
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) stop(); else start();
    });
    start();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bootTrace);
  } else {
    bootTrace();
  }
</script>

<style is:global>
  /* Stagger reveal on hero — single page-load choreography */
  .hero-eyebrow, .headline, .sub, .hero-ctas, .hero-trace, .hero-switchboard {
    opacity: 0;
    transform: translateY(8px);
    animation: hero-rise 700ms cubic-bezier(0.2, 0.7, 0.2, 1) forwards;
  }
  .hero-eyebrow    { animation-delay: 80ms; }
  .headline        { animation-delay: 180ms; }
  .sub             { animation-delay: 360ms; }
  .hero-ctas       { animation-delay: 500ms; }
  .hero-trace      { animation-delay: 700ms; }
  .hero-switchboard{ animation-delay: 340ms; }
  @keyframes hero-rise {
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-eyebrow, .headline, .sub, .hero-ctas, .hero-trace, .hero-switchboard {
      opacity: 1; transform: none; animation: none;
    }
  }
</style>

<style>
  /* ──────────────── HERO ──────────────── */
  .hero {
    padding: 64px 0 96px;
    border-top: none;
    overflow: hidden;
    position: relative;
  }
  .hero::before {
    /* faint margin marks evoking a typeset proof */
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 8% 24%, color-mix(in oklab, var(--emerald) 6%, transparent) 0%, transparent 35%),
      radial-gradient(circle at 92% 88%, color-mix(in oklab, var(--ink) 5%, transparent) 0%, transparent 35%);
    pointer-events: none;
    z-index: 0;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 72px;
    align-items: center;
    position: relative;
    z-index: 1;
    min-height: 72vh;
  }

  /* Hero — text column */
  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }
  .line-mark {
    display: inline-block;
    width: 36px;
    height: 1px;
    background: var(--emerald);
  }
  .eyebrow {
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--slate);
    font-weight: 500;
  }
  .headline {
    font-family: var(--serif);
    font-size: clamp(2.75rem, 6vw + 0.5rem, 5.75rem);
    line-height: 0.96;
    letter-spacing: -0.028em;
    font-weight: 400;
    color: var(--ink);
    margin: 0 0 32px;
  }
  .headline em {
    font-style: italic;
    color: var(--emerald);
  }
  .headline .dot {
    color: var(--emerald);
    font-style: normal;
  }
  .sub {
    font-family: var(--serif);
    font-size: clamp(1.05rem, 0.5vw + 1rem, 1.25rem);
    line-height: 1.45;
    color: var(--slate);
    margin: 0 0 36px;
    max-width: 38ch;
  }
  .watching-arrow {
    color: var(--emerald);
    font-family: var(--mono);
    margin-left: 2px;
  }
  .hero-ctas {
    display: flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
    margin-bottom: 44px;
  }

  /* Buttons (local to page; we replaced the old generic Button) */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    font-family: var(--mono);
    font-size: 11.5px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 14px 18px 13px;
    border-radius: 3px;
    text-decoration: none;
    border: 1px solid var(--ink);
    background: var(--ink);
    color: var(--bg);
    transition: background 200ms ease, color 200ms ease, transform 200ms ease, border-color 200ms ease;
    cursor: pointer;
    border-bottom: none;
    line-height: 1;
  }
  .btn-primary:hover {
    background: var(--ink-deep);
    color: var(--bg);
  }
  .btn-arrow {
    font-family: var(--mono);
    transition: transform 200ms ease;
  }
  .btn-primary:hover .btn-arrow {
    transform: translateX(4px);
  }
  .btn-ghost {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--slate);
    text-decoration: none;
    border-bottom: 1px solid var(--hair-2);
    padding: 4px 0 6px;
    transition: color 200ms ease, border-color 200ms ease;
  }
  .btn-ghost:hover {
    color: var(--emerald);
    border-bottom-color: var(--emerald);
  }
  .btn-light {
    border: 1px solid var(--bg);
    background: var(--bg);
    color: var(--ink);
  }
  .btn-light:hover {
    background: transparent;
    color: var(--bg);
    border-color: var(--bg);
  }
  .btn-light:hover .btn-arrow { transform: translateX(4px); }

  /* Email pair — used in hero and closer */
  .mail-pair {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .mail-link {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--slate);
    text-decoration: none;
    border-bottom: 1px solid var(--hair-2);
    padding: 4px 0 6px;
    transition: color 200ms ease, border-color 200ms ease;
  }
  .mail-link:hover {
    color: var(--emerald);
    border-bottom-color: var(--emerald);
  }
  .mail-sep {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--hair-2);
    user-select: none;
  }
  /* Closer variant — dark background */
  .mail-pair-light .mail-sep,
  .closer .mail-sep {
    color: color-mix(in oklab, var(--bg) 25%, transparent);
  }

  .hero-trace {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--slate);
    opacity: 0.7;
    padding-top: 20px;
    border-top: 1px dashed var(--hair-2);
    max-width: 56ch;
  }
  .trace-mark {
    color: var(--emerald);
    font-family: var(--mono);
    animation: trace-blink 1.4s steps(2, end) infinite;
  }
  @keyframes trace-blink {
    50% { opacity: 0.15; }
  }
  .trace-text {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    transition: opacity 300ms ease;
  }
  .trace-text.trace-fading {
    opacity: 0;
  }

  /* Hero — switchboard column */
  .hero-switchboard {
    width: 100%;
    align-self: center;
  }

  /* ──────────────── PILLARS STRIP ──────────────── */
  .pillars-strip {
    background: color-mix(in oklab, var(--bg-soft) 80%, transparent);
    border-top: 1px solid var(--hair);
    border-bottom: 1px solid var(--hair);
    padding: 88px 0;
    position: relative;
  }
  .pillars-strip::before {
    /* a slow horizontal wash to evoke a printed band */
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 12% 30%, color-mix(in oklab, var(--emerald) 5%, transparent), transparent 45%),
      radial-gradient(ellipse at 88% 70%, color-mix(in oklab, var(--ink) 4%, transparent), transparent 45%);
    pointer-events: none;
  }
  .pillars-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    position: relative;
    z-index: 1;
  }
  .pillar {
    padding: 0 40px;
    border-right: 1px solid var(--hair);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .pillar:first-child { padding-left: 0; }
  .pillar:last-child { padding-right: 0; border-right: none; }
  .pillar-id {
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--slate);
  }
  .pillar-id .roman {
    color: var(--emerald);
    font-weight: 500;
    margin-right: 1px;
  }
  .pillar-name {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 1.4vw + 0.9rem, 1.85rem);
    line-height: 1.1;
    letter-spacing: -0.014em;
    font-weight: 400;
    color: var(--ink);
    margin: 0;
    max-width: 18ch;
  }
  .pillar-name .dot {
    color: var(--emerald);
  }
  .pillar-spec {
    font-size: 10.5px;
    letter-spacing: 0.06em;
    color: var(--slate);
    margin: 0;
    line-height: 1.5;
  }

  /* ──────────────── MANIFESTO ──────────────── */
  .manifesto {
    padding: 144px 0 156px;
    border-top: 1px solid var(--hair);
    background: var(--bg);
    position: relative;
  }
  .manifesto-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }
  .manifesto-mark {
    display: inline-block;
    font-size: 10.5px;
    letter-spacing: 0.28em;
    color: var(--slate);
    margin-bottom: 56px;
    padding: 6px 12px;
    border: 1px solid var(--hair);
    border-radius: 2px;
  }
  .stanza {
    font-family: var(--serif);
    font-size: clamp(1.4rem, 1.5vw + 0.8rem, 1.85rem);
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--ink);
    margin: 0 0 36px;
  }
  .stanza:last-of-type { margin-bottom: 0; }
  .stanza em {
    font-style: italic;
    color: var(--emerald);
  }
  .manifesto-corner {
    display: flex;
    justify-content: space-between;
    font-size: 9.5px;
    letter-spacing: 0.2em;
    color: var(--slate);
    margin-top: 80px;
    padding-top: 22px;
    border-top: 1px dashed var(--hair-2);
    text-transform: uppercase;
  }

  /* ──────────────── CLOSER ──────────────── */
  .closer {
    padding: 128px 0 96px;
    background:
      radial-gradient(ellipse at top, color-mix(in oklab, var(--emerald) 14%, var(--ink-deep)) 0%, var(--ink-deep) 60%);
    color: var(--bg);
    border-top: 1px solid var(--ink-deep);
    position: relative;
    overflow: hidden;
  }
  .closer-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, color-mix(in oklab, var(--bg) 5%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in oklab, var(--bg) 5%, transparent) 1px, transparent 1px);
    background-size: 56px 56px;
    background-position: -1px -1px;
    pointer-events: none;
    opacity: 0.7;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 80%);
  }
  .closer-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 36px;
  }
  .closer-meta {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    font-size: 10.5px;
    letter-spacing: 0.2em;
    color: color-mix(in oklab, var(--bg) 80%, transparent);
    text-transform: uppercase;
  }
  .closer-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--emerald);
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--emerald) 22%, transparent);
    animation: nav-pulse 1.8s ease-in-out infinite;
  }
  .closer-meta-sep {
    opacity: 0.4;
  }
  .closer-headline {
    font-family: var(--serif);
    font-size: clamp(3rem, 6vw + 0.5rem, 5.5rem);
    line-height: 0.96;
    letter-spacing: -0.028em;
    font-weight: 400;
    color: var(--bg);
    margin: 0;
    max-width: 18ch;
  }
  .closer-headline em {
    font-style: italic;
    color: color-mix(in oklab, var(--emerald) 90%, var(--bg));
  }
  .closer-headline .dot {
    color: var(--emerald);
    font-style: normal;
  }
  .closer-sub {
    font-family: var(--serif);
    font-size: clamp(1.1rem, 0.6vw + 1rem, 1.3rem);
    color: color-mix(in oklab, var(--bg) 78%, transparent);
    margin: 0;
    font-style: italic;
  }
  .closer-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }
  .closer-mail {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in oklab, var(--bg) 70%, transparent);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in oklab, var(--bg) 25%, transparent);
    padding: 4px 0 6px;
    transition: color 200ms ease, border-color 200ms ease;
  }
  .closer-mail:hover {
    color: var(--emerald);
    border-bottom-color: var(--emerald);
  }

  /* ──────────────── RESPONSIVE ──────────────── */
  @media (max-width: 1080px) {
    .hero-grid {
      gap: 48px;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    }
  }
  @media (max-width: 900px) {
    .hero { padding: 40px 0 80px; }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 48px;
      min-height: 0;
    }
    .hero-text { order: 1; }
    .hero-switchboard { order: 2; }
    .manifesto { padding: 96px 0 100px; }
    .closer { padding: 96px 0 80px; }
    .pillars-strip { padding: 64px 0; }
    .pillars-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .pillar {
      padding: 0;
      border-right: none;
      border-bottom: 1px solid var(--hair);
      padding-bottom: 28px;
    }
    .pillar:last-child { border-bottom: none; padding-bottom: 0; }
  }
  @media (max-width: 560px) {
    .hero { padding: 28px 0 64px; }
    .headline { font-size: clamp(3rem, 14vw, 4.5rem); }
    .hero-trace { display: none; }
    .manifesto-corner {
      flex-direction: column;
      gap: 6px;
      align-items: flex-start;
    }
    .closer-meta {
      flex-wrap: wrap;
      justify-content: center;
      gap: 6px 10px;
    }
    .closer-meta-sep { display: none; }
  }
</style>
